{
  acme_dns cloudflare {env.CF_API_TOKEN}
}

*.hub.ptclab.org {
  tls {
    dns cloudflare {env.CF_API_TOKEN}
    resolvers 1.1.1.1
  }

  @hp host hp.hub.ptclab.org

  handle @hp {
    reverse_proxy 10.17.10.20:3000
  }
}

*.oc.ptclab.org {
  tls {
    dns cloudflare {env.CF_API_TOKEN}
    resolvers 1.1.1.1
  }

  @cloud host cloud.oc.ptclab.org

  handle @cloud {
    reverse_proxy 10.17.10.31:9200
  }
}
